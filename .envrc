# ─────────────────────────────────────────────────────────────────────────────
# .envrc — loaded automatically by direnv when you cd into this directory.
# Run `direnv allow` once after cloning to activate.
# Copy this file to .envrc and fill in real secrets. Never commit secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
# Port the HTTP server listens on.
export APP_PORT=8080

# Runtime environment: development | staging | production
# Affects CORS policy and log verbosity.
export APP_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL host. Points to localhost for local dev; use the Docker service
# name (e.g. "postgres") when running inside docker-compose.
export DB_HOST=localhost

# PostgreSQL port.
export DB_PORT=5432

# Database credentials — match the values in docker-compose.yml.
export DB_USER=postgres
export DB_PASSWORD=postgres

# Database name.
export DB_NAME=myapp

# Connection pool: maximum concurrent connections to PostgreSQL.
export DB_MAX_CONNS=25

# Connection pool: minimum idle connections kept alive.
export DB_MIN_CONNS=5
