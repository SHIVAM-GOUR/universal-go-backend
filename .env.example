# ─────────────────────────────────────────────────────────────────────────────
# .env.example — documents every environment variable the application reads.
# Copy to .envrc (for direnv) or export manually. Never commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_PORT=8080           # Port the HTTP server listens on. Default: 8080
APP_ENV=development     # Environment tag. Values: development | staging | production

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost       # PostgreSQL hostname or IP. Default: localhost
DB_PORT=5432            # PostgreSQL port. Default: 5432
DB_USER=postgres        # REQUIRED. Database user.
DB_PASSWORD=postgres    # REQUIRED. Database password.
DB_NAME=myapp           # REQUIRED. Database name.
DB_MAX_CONNS=25         # Max open connections in the pool. Default: 25
DB_MIN_CONNS=5          # Min idle connections in the pool. Default: 5
